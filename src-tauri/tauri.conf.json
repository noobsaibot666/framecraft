{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Framecraft",
  "version": "0.1.0",
  "identifier": "com.alan.framecraft",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Framecraft",
        "width": 1280,
        "height": 840,
        "minWidth": 1100,
        "minHeight": 680,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost tauri://localhost; media-src 'self' data: blob:; connect-src 'self' https://api.anthropic.com https://api.openai.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*", "$HOME/**/*", "/Volumes/**/*", "**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
